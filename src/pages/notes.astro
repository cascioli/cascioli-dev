---
import Layout from '../layouts/Layout.astro';
---

<Layout
  title="cascioli. — Notes"
  description="Note di Simone Cascioli su Flutter, AI engineering, cybersecurity e sviluppo indipendente. Saggi brevi, frammenti di codice, idee a metà."
  tickerText="LATEST POST — Hardening Flutter: Production-ready security">

  <main class="px-6 ambient">
    <article class="max-w-[760px] mx-auto pt-20 lg:pt-28 pb-32">

      <div class="head-in font-mono text-[11.5px] tracking-[0.22em] uppercase text-emerald-500 mb-6">
        Notes &nbsp;·&nbsp; <span class="text-zinc-500">a digital garden</span>
      </div>

      <h1 class="head-in-2 font-sans font-semibold tracking-[-0.025em] text-zinc-50 text-[56px] sm:text-[72px] leading-[1.02]">
        Things I'm thinking about<span class="text-emerald-500">.</span>
      </h1>

      <p class="head-in-3 mt-7 text-zinc-400 text-[18px] leading-[1.7] max-w-[58ch]">
        Saggi brevi, frammenti di codice, idee a metà. Niente calendario editoriale.
        Pubblico quando un'idea è abbastanza chiara da sostenersi da sola.
      </p>

      <!-- Filters -->
      <nav id="filters" class="head-in-4 mt-12 -mx-2 flex flex-wrap items-center gap-1 pb-6 border-b border-zinc-900">
        <button class="filter-pill is-active" data-tag="all">All <span class="pill-count">5</span></button>
        <button class="filter-pill" data-tag="flutter-arch">Flutter <span class="pill-count">1</span></button>
        <button class="filter-pill" data-tag="ai-engineering">AI <span class="pill-count">2</span></button>
        <button class="filter-pill" data-tag="cybersecurity">Cybersec <span class="pill-count">1</span></button>
        <button class="filter-pill" data-tag="independent-dev">Indie <span class="pill-count">1</span></button>
        <button id="searchTrigger"
                class="search-fab ml-auto inline-flex items-center gap-2 h-9 px-3 rounded-md border border-zinc-800 text-zinc-500 font-mono text-[12px]">
          <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
          <span>search</span>
          <span class="ml-1 flex items-center gap-1"><span class="kbd">/</span></span>
        </button>
      </nav>

      <!-- Feed -->
      <div id="feed" class="mt-2"></div>
      <div id="emptyFeed" class="hidden py-24 text-center text-zinc-600 font-mono text-sm">No notes match this filter.</div>

      <!-- Footer -->
      <footer class="mt-32 pt-10 border-t border-zinc-900 flex flex-col sm:flex-row items-start sm:items-center justify-between gap-4">
        <p class="font-mono text-[11.5px] text-zinc-600 tracking-wider">
          <span class="text-emerald-500">●</span> &nbsp;Updated weekly &nbsp;·&nbsp; rss available
        </p>
        <div class="flex items-center gap-5 font-mono text-[12px]">
          <a href="#" class="text-zinc-500 hover:text-emerald-400 transition-colors">rss.xml ↗</a>
          <a href="/#contact" class="text-zinc-500 hover:text-emerald-400 transition-colors">say hi ↗</a>
        </div>
      </footer>

    </article>
  </main>

  <!-- Floating search hint -->
  <div class="fixed bottom-5 right-5 z-30 hidden sm:flex">
    <button id="searchTrigger2"
            class="search-fab inline-flex items-center gap-2 h-9 px-3 rounded-full border border-zinc-800 bg-zinc-950/70 backdrop-blur text-zinc-500 font-mono text-[11.5px] shadow-[0_10px_30px_-10px_rgba(0,0,0,0.6)]">
      <span>Press</span>
      <span class="kbd">/</span>
      <span>to search</span>
    </button>
  </div>

</Layout>

<style is:global>
  .ambient::before {
    content: "";
    position: fixed; inset: 0;
    background: radial-gradient(ellipse 50% 30% at 50% 0%, rgba(16,185,129,0.06), transparent 70%);
    pointer-events: none;
    z-index: -1;
  }

  .filter-pill {
    display: inline-flex; align-items: center; gap: 6px;
    padding: 6px 14px; border-radius: 999px;
    font-size: 13.5px; color: #71717a;
    transition: color 220ms ease, background-color 220ms ease;
    cursor: pointer;
  }
  .filter-pill:hover { color: #d4d4d8; }
  .filter-pill.is-active {
    color: #fafafa;
    background-color: rgba(16,185,129,0.10);
    box-shadow: inset 0 0 0 1px rgba(16,185,129,0.35);
  }
  .filter-pill.is-active .pill-count { color: #34d399; }
  .pill-count { color: #52525b; font-family: 'Geist Mono', monospace; font-size: 11px; }

  .note { display: block; padding: 28px 0; border-bottom: 1px solid #18181b; }
  .note-title {
    font-family: 'Geist', sans-serif; font-weight: 600; font-size: 28px;
    line-height: 1.22; letter-spacing: -0.018em; color: #fafafa;
    transition: color 200ms ease; text-wrap: balance;
  }
  .note-title .arrow {
    display: inline-block; margin-left: 4px; color: #3f3f46;
    transition: color 200ms ease, transform 220ms ease;
    transform: translate(-4px, 0) rotate(-45deg); font-weight: 500;
  }
  .note:hover .note-title { color: #ffffff; }
  .note:hover .note-title .arrow { color: #10b981; transform: translate(0, -2px) rotate(-45deg); }
  .note-preview {
    color: #a1a1aa; font-size: 16.5px; line-height: 1.6; margin-top: 10px;
    max-width: 64ch; text-wrap: pretty;
    display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden;
  }
  .note-meta { font-family: 'Geist Mono', monospace; font-size: 11px; color: #52525b; letter-spacing: 0.04em; }
  .note-meta .tag { color: #71717a; transition: color 200ms ease; }
  .note:hover .note-meta .tag { color: #34d399; }

  .year-divider { display: flex; align-items: baseline; gap: 16px; margin-top: 56px; margin-bottom: 8px; }
  .year-divider .y-label { font-family: 'Geist Mono', monospace; font-size: 11px; letter-spacing: 0.18em; text-transform: uppercase; color: #52525b; }
  .year-divider .y-line  { flex: 1; height: 1px; background: linear-gradient(to right, #27272a, transparent 90%); }

  @keyframes noteFadeIn { from { opacity: 0; transform: translateY(6px); } to { opacity: 1; transform: translateY(0); } }
  .feed-anim .note, .feed-anim .year-divider { animation: noteFadeIn 420ms cubic-bezier(0.22, 1, 0.36, 1) both; }
  .feed-anim .note:nth-child(2) { animation-delay: 40ms; }
  .feed-anim .note:nth-child(3) { animation-delay: 80ms; }
  .feed-anim .note:nth-child(4) { animation-delay: 120ms; }
  .feed-anim .note:nth-child(5) { animation-delay: 160ms; }

  .search-fab { transition: background-color 200ms, border-color 200ms, color 200ms, transform 200ms; }
  .search-fab:hover { color: #fafafa; border-color: rgba(16,185,129,0.55); background-color: rgba(16,185,129,0.08); }

  @keyframes headIn { from { opacity: 0; transform: translateY(10px); } to { opacity: 1; transform: translateY(0); } }
  .head-in   { animation: headIn 520ms cubic-bezier(0.22,1,0.36,1) both; }
  .head-in-2 { animation: headIn 520ms cubic-bezier(0.22,1,0.36,1) 80ms  both; }
  .head-in-3 { animation: headIn 520ms cubic-bezier(0.22,1,0.36,1) 160ms both; }
  .head-in-4 { animation: headIn 520ms cubic-bezier(0.22,1,0.36,1) 240ms both; }
</style>

<script>
  const NOTES_DATA = [
    { id: 'flutter-hardening', title: 'Hardening Flutter: Production-ready security',             preview: "Da SSL pinning a obfuscation: come spedire un'app Flutter senza farsi sgridare dal pentester.", tag: 'flutter-arch',     date: '2026-05-10', readMin: 9  },
    { id: 'gemini-structured',  title: 'Structured Output con Gemini: trasformare foto in dati',   preview: 'Pattern per estrarre JSON deterministico da prompt visivi senza perdere la sanità mentale.',  tag: 'ai-engineering',  date: '2026-04-28', readMin: 7  },
    { id: 'fuzzy-router',       title: 'Fuzzy Matching in Go: la logica dietro fuzzyrouter',       preview: 'Trie + Levenshtein-lite: come ho costruito un router HTTP che indovina cosa volevi davvero.',   tag: 'independent-dev', date: '2026-04-12', readMin: 12 },
    { id: 'osint-footprints',   title: 'Mapping Digital Footprints: OSINT & Cybersec',             preview: "Costruire una mappa della propria esposizione pubblica con strumenti open-source.",            tag: 'cybersecurity',   date: '2026-03-30', readMin: 11 },
    { id: 'ai-chronicles',      title: 'AI Chronicles: gamification con Gemini',                   preview: 'Un esperimento in cui Gemini scrive avventure testuali a turni, con regole e stato persistente.', tag: 'ai-engineering', date: '2026-03-14', readMin: 6  },
  ];

  const TAG_LABELS: Record<string, string> = {
    'flutter-arch':    'flutter',
    'ai-engineering':  'ai',
    'cybersecurity':   'cybersec',
    'independent-dev': 'indie',
  };

  let _nc: AbortController | null = null;

  document.addEventListener('astro:page-load', () => {
    _nc?.abort();
    _nc = new AbortController();
    const { signal } = _nc;

    const state = { tag: 'all' };
    const feedEl  = document.getElementById('feed')!;
    const emptyEl = document.getElementById('emptyFeed')!;

    function fmtDate(iso: string) {
      return new Date(iso).toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' });
    }

    function renderFeed() {
      const filtered = NOTES_DATA.filter(n => state.tag === 'all' || n.tag === state.tag);
      const byYear = new Map<number, typeof NOTES_DATA>();
      filtered.forEach(n => {
        const y = new Date(n.date).getFullYear();
        if (!byYear.has(y)) byYear.set(y, []);
        byYear.get(y)!.push(n);
      });
      const years = [...byYear.keys()].sort((a, b) => b - a);

      if (filtered.length === 0) {
        emptyEl.classList.remove('hidden');
        feedEl.innerHTML = '';
      } else {
        emptyEl.classList.add('hidden');
        let html = '';
        years.forEach(y => {
          html += `<div class="year-divider"><span class="y-label">${y}</span><span class="y-line"></span></div>`;
          byYear.get(y)!.sort((a, b) => b.date.localeCompare(a.date)).forEach(n => {
            html += `
              <a href="#" class="note">
                <div class="note-meta flex items-center gap-3">
                  <span>${fmtDate(n.date)}</span>
                  <span class="text-zinc-700">·</span>
                  <span>${n.readMin} min read</span>
                  <span class="text-zinc-700">·</span>
                  <span class="tag">#${TAG_LABELS[n.tag] || n.tag}</span>
                </div>
                <h2 class="note-title mt-3">${n.title}<span class="arrow">↗</span></h2>
                <p class="note-preview">${n.preview}</p>
              </a>`;
          });
        });
        feedEl.innerHTML = html;
      }

      feedEl.classList.remove('feed-anim');
      void feedEl.offsetWidth;
      feedEl.classList.add('feed-anim');
    }

    document.querySelectorAll('#filters .filter-pill').forEach(btn => {
      btn.addEventListener('click', () => {
        if ((btn as HTMLElement).classList.contains('is-active')) return;
        state.tag = (btn as HTMLElement).dataset.tag!;
        document.querySelectorAll('#filters .filter-pill').forEach(b => b.classList.toggle('is-active', b === btn));
        renderFeed();
      });
    });

    document.addEventListener('palette:selectTag', (e: Event) => {
      const tag = (e as CustomEvent).detail.tag;
      state.tag = tag;
      document.querySelectorAll('#filters .filter-pill').forEach(b =>
        b.classList.toggle('is-active', (b as HTMLElement).dataset.tag === tag)
      );
      renderFeed();
    }, { signal });

    document.getElementById('searchTrigger')?.addEventListener('click',  () => (window as any).openCommandPalette?.());
    document.getElementById('searchTrigger2')?.addEventListener('click', () => (window as any).openCommandPalette?.());

    renderFeed();
    document.dispatchEvent(new CustomEvent('palette:setNotes', { detail: { notes: NOTES_DATA } }));
  });
</script>
