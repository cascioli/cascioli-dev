---
import '../styles/global.css';
import { ClientRouter } from 'astro:transitions';
import Ticker from '../components/Ticker.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import CommandPalette from '../components/CommandPalette.astro';

interface Props {
  title: string;
  description?: string;
  image?: string;
  bodyClass?: string;
  tickerText?: string;
  showFooter?: boolean;
  type?: 'website' | 'article';
  keywords?: string;
  publishedTime?: string;
  modifiedTime?: string;
  articleTags?: string[];
  jsonLd?: object | object[];
}

const {
  title,
  description = 'Software Architect freelance specializzato in sistemi AI-native e cybersecurity. Note, progetti e pensieri di Simone Cascioli.',
  image,
  bodyClass = 'min-h-screen',
  tickerText,
  showFooter = false,
  type = 'website',
  keywords,
  publishedTime,
  modifiedTime,
  articleTags,
  jsonLd,
} = Astro.props;

const SITE = 'https://simonecascioli.it';
const canonical  = new URL(Astro.url.pathname, SITE).href;
const ogImage    = new URL(image ?? '/assets/profilo-color.jpg', SITE).href;

const DEFAULT_ACTIONS = [
  { kind: 'page' as const, title: 'Go to Home',   hint: 'navigate', href: '/'        },
  { kind: 'page' as const, title: 'Go to Work',   hint: 'navigate', href: '/work'    },
  { kind: 'page' as const, title: 'Go to About',  hint: 'navigate', href: '/about'   },
  { kind: 'page' as const, title: 'Go to Notes',  hint: 'navigate', href: '/notes'   },
  { kind: 'page' as const, title: 'Get in touch', hint: 'navigate', href: '/contact' },
];
---

<!doctype html>
<html lang="it">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />

  <title>{title}</title>
  <meta name="description" content={description} />
  <meta name="robots" content="index, follow" />
  <meta name="author" content="Simone Cascioli" />
  {keywords && <meta name="keywords" content={keywords} />}
  <link rel="canonical" href={canonical} />
  <link rel="alternate" hreflang="it"        href={canonical} />
  <link rel="alternate" hreflang="x-default" href={canonical} />

  <!-- Open Graph -->
  <meta property="og:type"        content={type} />
  <meta property="og:url"         content={canonical} />
  <meta property="og:title"       content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:locale"      content="it_IT" />
  <meta property="og:site_name"   content="cascioli." />
  <meta property="og:image"       content={ogImage} />
  <meta property="og:image:alt"   content={`${title} — simonecascioli.it`} />

  <!-- Twitter / X -->
  <meta name="twitter:card"        content={type === 'article' || image ? "summary_large_image" : "summary"} />
  <meta name="twitter:site"        content="@simlimone" />
  <meta name="twitter:creator"     content="@simlimone" />
  <meta name="twitter:title"       content={title} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image"       content={ogImage} />
  <meta name="twitter:image:alt"   content={`${title} — simonecascioli.it`} />

  {type === 'article' && publishedTime && <meta property="article:published_time" content={publishedTime} />}
  {type === 'article' && modifiedTime && <meta property="article:modified_time" content={modifiedTime} />}
  {type === 'article' && <meta property="article:author" content="https://simonecascioli.it/about" />}
  {type === 'article' && articleTags && articleTags.map(tag => <meta property="article:tag" content={tag} />)}

  <!-- Sitemap + RSS -->
  <link rel="sitemap" type="application/xml" href="/sitemap-index.xml" />
  <link rel="alternate" type="application/rss+xml" title="Note — cascioli." href="/rss.xml" />

  <!-- JSON-LD -->
  {jsonLd && <script type="application/ld+json" set:html={JSON.stringify(Array.isArray(jsonLd) ? jsonLd : [jsonLd])} />}

  <!-- Favicons -->
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <link rel="shortcut icon" href="/favicon.svg" />

  <!-- View Transitions -->
  <ClientRouter />

  <!-- Fonts -->
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Geist:wght@300;400;500;600;700;800&family=Geist+Mono:wght@400;500;600&display=swap" rel="stylesheet" />
</head>
<body class={bodyClass}>
  {tickerText && <Ticker latestItem={tickerText} />}
  <Navbar />
  <slot />
  {showFooter && <Footer />}
  <CommandPalette notes={[]} quickActions={DEFAULT_ACTIONS} />
</body>
</html>
