---
export interface Note {
  id: string;
  title: string;
  preview: string;
  tag: string;
  date: string;
  readMin: number;
}

export interface QuickAction {
  kind: 'page' | 'cmd';
  title: string;
  hint: string;
  href?: string;
}

interface Props {
  notes: Note[];
  quickActions: QuickAction[];
}

const { notes, quickActions } = Astro.props;
---

<div id="palette" class="palette-hidden fixed inset-0 z-[60]">
  <div class="palette-backdrop absolute inset-0"></div>
  <div class="absolute inset-0 flex items-start justify-center pt-[12vh] px-4">
    <div class="palette-window w-full max-w-[640px] rounded-xl overflow-hidden bg-zinc-950/95 border border-emerald-500/60">
      <div class="flex items-center gap-3 px-4 h-14 border-b border-zinc-800">
        <svg class="text-emerald-500" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2">
          <circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/>
        </svg>
        <input id="paletteInput" type="text" autocomplete="off" spellcheck="false"
               placeholder="Search notes, tags, repos…"
               class="flex-1 bg-transparent outline-none text-zinc-100 placeholder:text-zinc-600 font-sans text-[15px]" />
        <span class="kbd">esc</span>
      </div>
      <div id="paletteResults" class="max-h-[52vh] overflow-y-auto py-2"></div>
      <div id="paletteEmpty" class="hidden px-5 py-10 text-center font-mono text-[12px] text-zinc-500">
        <span class="text-emerald-500">$</span> no matches — try another query
      </div>
      <div class="h-10 px-4 flex items-center gap-5 border-t border-zinc-800 bg-[#0a0a0b] font-mono text-[11px] text-zinc-500">
        <span class="flex items-center gap-1.5"><span class="kbd">↑</span><span class="kbd">↓</span><span class="ml-1">to navigate</span></span>
        <span class="flex items-center gap-1.5"><span class="kbd">↵</span><span class="ml-1">enter to select</span></span>
        <span class="flex items-center gap-1.5"><span class="kbd">esc</span><span class="ml-1">to close</span></span>
        <span class="ml-auto flex items-center gap-1.5"><span class="text-emerald-500">●</span> palette ready</span>
      </div>
    </div>
  </div>
</div>

<style is:global>
  .palette-backdrop {
    background: rgba(3, 7, 18, 0.7);
    backdrop-filter: blur(6px);
    -webkit-backdrop-filter: blur(6px);
    transition: opacity 180ms ease;
  }
  .palette-window {
    box-shadow:
      0 0 0 1px rgba(16,185,129,0.55),
      0 0 0 4px rgba(16,185,129,0.10),
      0 30px 80px -10px rgba(0,0,0,0.7),
      0 0 60px rgba(16,185,129,0.25);
    transition: opacity 180ms ease, transform 220ms cubic-bezier(0.22,1,0.36,1);
  }
  .palette-hidden { pointer-events: none; }
  .palette-hidden .palette-backdrop { opacity: 0; }
  .palette-hidden .palette-window   { opacity: 0; transform: translateY(-8px) scale(0.985); }
  .palette-item { transition: background-color 120ms ease; }
  .palette-item.is-active {
    background-color: rgba(16,185,129,0.10);
    box-shadow: inset 2px 0 0 0 #10b981;
  }
  .kbd {
    display: inline-flex; align-items: center; justify-content: center;
    min-width: 18px; height: 20px;
    padding: 0 6px;
    font-family: 'Geist Mono', monospace;
    font-size: 10.5px;
    color: #d4d4d8;
    background: #18181b;
    border: 1px solid #3f3f46;
    border-bottom-width: 2px;
    border-radius: 4px;
    line-height: 1;
  }
</style>

<script define:vars={{ notes, quickActions }}>
  let paletteNotes = [...notes];
  const QUICK_ACTIONS = quickActions;

  document.addEventListener('palette:setNotes', (e) => { paletteNotes = e.detail.notes; });

  const TAG_LABELS = {
    'flutter-arch':    'flutter',
    'ai-engineering':  'ai',
    'cybersecurity':   'cybersec',
    'independent-dev': 'indie',
  };

  const palette      = document.getElementById('palette');
  const paletteInput = document.getElementById('paletteInput');
  const paletteRes   = document.getElementById('paletteResults');
  const paletteEmpty = document.getElementById('paletteEmpty');

  let activeIdx = 0;
  let currentList = [];

  function fmtDateShort(iso) {
    return new Date(iso).toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: '2-digit' });
  }

  function openPalette() {
    palette.classList.remove('palette-hidden');
    setTimeout(() => paletteInput.focus(), 30);
    paletteInput.value = '';
    renderPalette('');
  }
  function closePalette() {
    palette.classList.add('palette-hidden');
    paletteInput.blur();
  }

  function renderPalette(q) {
    q = (q || '').trim().toLowerCase();
    const noteResults = paletteNotes
      .filter(n => !q || n.title.toLowerCase().includes(q) || n.preview.toLowerCase().includes(q) || n.tag.toLowerCase().includes(q))
      .map(n => ({ kind: 'note', title: n.title, hint: '#' + (TAG_LABELS[n.tag] || n.tag) + ' · ' + fmtDateShort(n.date), id: n.id, tag: n.tag }));

    const actionResults = QUICK_ACTIONS.filter(a => !q || a.title.toLowerCase().includes(q));
    currentList = [...noteResults, ...actionResults];
    activeIdx = 0;

    if (currentList.length === 0) {
      paletteRes.innerHTML = '';
      paletteEmpty.classList.remove('hidden');
      return;
    }
    paletteEmpty.classList.add('hidden');

    let html = '';
    if (noteResults.length) {
      html += `<div class="px-5 pt-3 pb-1 font-mono text-[10px] uppercase tracking-[0.16em] text-zinc-600">Notes</div>`;
      noteResults.forEach((r, i) => html += paletteRow(r, i));
    }
    if (actionResults.length) {
      html += `<div class="px-5 pt-3 pb-1 font-mono text-[10px] uppercase tracking-[0.16em] text-zinc-600">Quick actions</div>`;
      actionResults.forEach((r, j) => html += paletteRow(r, noteResults.length + j));
    }
    paletteRes.innerHTML = html;
    updateActive();
  }

  function paletteRow(r, idx) {
    const icon = r.kind === 'note'
      ? `<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#34d399" stroke-width="1.8"><path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8z"/><polyline points="14 2 14 8 20 8"/></svg>`
      : `<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#a1a1aa" stroke-width="2"><path d="M5 12h14"/><path d="M13 5l7 7-7 7"/></svg>`;
    return `
      <div class="palette-item px-3 mx-2 my-0.5 rounded-md flex items-center gap-3 py-2.5 cursor-pointer" data-idx="${idx}">
        <span class="h-7 w-7 grid place-items-center rounded-md bg-zinc-900 border border-zinc-800">${icon}</span>
        <div class="flex-1 min-w-0">
          <div class="font-sans text-[14px] text-zinc-100 truncate">${r.title}</div>
          <div class="font-mono text-[11px] text-zinc-500 truncate">${r.hint || ''}</div>
        </div>
      </div>`;
  }

  function updateActive() {
    paletteRes.querySelectorAll('.palette-item').forEach((el, i) => {
      el.classList.toggle('is-active', i === activeIdx);
    });
    const active = paletteRes.querySelector('.palette-item.is-active');
    if (active) active.scrollIntoView({ block: 'nearest' });
  }

  function commitActive() {
    const item = currentList[activeIdx];
    if (!item) return;
    if (item.kind === 'note') {
      document.dispatchEvent(new CustomEvent('palette:selectTag', { detail: { tag: item.tag } }));
      closePalette();
    } else if (item.kind === 'page' && item.href) {
      window.location.href = item.href;
    } else {
      closePalette();
    }
  }

  // Expose open for external triggers
  window.openCommandPalette = openPalette;

  document.addEventListener('keydown', (e) => {
    const tgt = e.target;
    const inField = tgt && (tgt.tagName === 'INPUT' || tgt.tagName === 'TEXTAREA' || tgt.isContentEditable);
    const isMod = e.metaKey || e.ctrlKey;

    if (isMod && (e.key === 'k' || e.key === 'K')) {
      e.preventDefault();
      palette.classList.contains('palette-hidden') ? openPalette() : closePalette();
      return;
    }
    if (e.key === '/' && !inField && palette.classList.contains('palette-hidden')) {
      e.preventDefault(); openPalette(); return;
    }
    if (palette.classList.contains('palette-hidden')) return;

    if (e.key === 'Escape')         { e.preventDefault(); closePalette(); }
    else if (e.key === 'ArrowDown') { e.preventDefault(); if (currentList.length) { activeIdx = (activeIdx + 1) % currentList.length; updateActive(); } }
    else if (e.key === 'ArrowUp')   { e.preventDefault(); if (currentList.length) { activeIdx = (activeIdx - 1 + currentList.length) % currentList.length; updateActive(); } }
    else if (e.key === 'Enter')     { e.preventDefault(); commitActive(); }
  });

  paletteInput.addEventListener('input', (e) => renderPalette(e.target.value));
  palette.addEventListener('click', (e) => {
    if (e.target === palette.querySelector('.palette-backdrop')) { closePalette(); return; }
    const row = e.target.closest('.palette-item');
    if (row) { activeIdx = parseInt(row.dataset.idx, 10); updateActive(); commitActive(); }
  });
  paletteRes.addEventListener('mousemove', (e) => {
    const row = e.target.closest('.palette-item');
    if (!row) return;
    const idx = parseInt(row.dataset.idx, 10);
    if (idx !== activeIdx) { activeIdx = idx; updateActive(); }
  });
</script>
